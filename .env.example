# =====================================================================
#  Variables de entorno — Sistema de Reclutamiento Automatizado
#  Configurar como "secrets" de las Edge Functions:
#    supabase secrets set --env-file ./.env   (NO subir el .env real al repo)
#
#  Sin las claves de servicios externos, el sistema funciona en MODO SIMULADO:
#  no envía WhatsApp/email ni llama al LLM, pero el pipeline avanza para que
#  puedas probar el flujo completo. (Apéndice A del PRD = configuración manual.)
# =====================================================================

# --- Supabase (SUPABASE_URL / SERVICE_ROLE / ANON se autoinyectan en el
#     runtime de Edge Functions; defínelas solo para scripts locales) ---
SUPABASE_URL=https://lcqugobrchkenkawxlfj.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- Dominios y enlaces ---
REC_ALLOWED_ORIGINS=https://raaamp.co,https://www.raaamp.co,https://app.raaamp.co
REC_PUBLIC_BASE_URL=https://raaamp.co          # base de /prueba y /test (donde despliegues web/)
REC_RESPONSABLE_EMAIL=                          # correo del responsable (alertas I01/I02/I03)
REC_EMAIL_FROM=Reclutamiento raaamp <no-reply@raaamp.co>

# --- Modelo de lenguaje (screening de CV / apoyo a la prueba) ---
ANTHROPIC_API_KEY=                              # https://console.anthropic.com
LLM_MODEL=claude-sonnet-4-6                     # opus-4-8 | sonnet-4-6 | haiku-4-5-20251001

# --- WhatsApp Business API (BSP: Meta Cloud API por defecto) ---
WHATSAPP_TOKEN=                                 # token permanente del BSP / Meta
WHATSAPP_PHONE_NUMBER_ID=                       # id del número de WhatsApp
WHATSAPP_API_VERSION=v21.0
WHATSAPP_VERIFY_TOKEN=raaamp-verify             # token de verificación del webhook (tú lo eliges)

# --- Email (Resend por defecto) ---
RESEND_API_KEY=                                 # https://resend.com
